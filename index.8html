    <script>

        // Tabs

        document.querySelectorAll('.act-tab').forEach(tab => {

            tab.addEventListener('click', () => {

                document.querySelectorAll('.act-tab').forEach(t => t.classList.remove('active'));

                document.querySelectorAll('.act-panel').forEach(p => p.classList.remove('active'));

                tab.classList.add('active');

                document.getElementById('panel-' + tab.dataset.panel).classList.add('active');

            });

        });



        // Testimonial nav

        const ts = document.getElementById('test-scroll');

        document.getElementById('btn-prev').onclick = () => ts.scrollBy({ left: -340, behavior: 'smooth' });

        document.getElementById('btn-next').onclick = () => ts.scrollBy({ left: 340, behavior: 'smooth' });



        // Fade in

        const io = new IntersectionObserver(entries => {

            entries.forEach((e, i) => {

                if (e.isIntersecting) setTimeout(() => e.target.classList.add('in'), i * 70);

            });

        }, { threshold: 0.1 });

        document.querySelectorAll('.fade').forEach(el => io.observe(el));



        // ── Typewriter Animation ─────────────────────────────────────────────────────

        (function () {

            var pairs = [

                { p: 'Departments work in silos.', s: '\u2192 And clash when they collaborate.' },

                { p: 'Managers get promoted.', s: '\u2192 But never taught how to lead.' },

                { p: 'A new generation joins.', s: '\u2192 Traditional engagement doesn\u2019t work.' },

                { p: 'Teams are overworked.', s: '\u2192 Stressed. Sedentary. Disengaged.' },

                { p: 'You keep hiring.', s: '\u2192 Culture keeps getting diluted.' }

            ];

            var container = document.getElementById('tw-block');

            var aftermath = document.getElementById('hero-aftermath');

            var speed = 38, pause = 750, idx = 0, char = 0, phase = 'primary', lineObj = null;

            function mkLine() {

                var wrap = document.createElement('div'); wrap.className = 'tw-line';

                var p1 = document.createElement('span'); p1.className = 'tw-primary';

                var cur = document.createElement('span'); cur.className = 'tw-cursor'; cur.textContent = '|';

                var p2 = document.createElement('span'); p2.className = 'tw-secondary';

                p1.appendChild(cur); wrap.appendChild(p1); wrap.appendChild(p2);

                container.appendChild(wrap);

                requestAnimationFrame(function () { wrap.classList.add('tw-visible'); });

                return { wrap: wrap, p1: p1, p2: p2, cur: cur };

            }

            function tick() {

                if (!lineObj) lineObj = mkLine();

                var pair = pairs[idx];

                if (phase === 'primary') {

                    if (char < pair.p.length) {

                        lineObj.p1.insertBefore(document.createTextNode(pair.p[char]), lineObj.cur);

                        char++; setTimeout(tick, speed);

                    } else {

                        phase = 'secondary'; char = 0;

                        setTimeout(function () {

                            lineObj.p2.appendChild(lineObj.cur);

                            tick();

                        }, pause / 2);

                    }

                } else {

                    if (char < pair.s.length) {

                        lineObj.p2.insertBefore(document.createTextNode(pair.s[char]), lineObj.cur);

                        char++; setTimeout(tick, speed);

                    } else {

                        lineObj.cur.remove();

                        idx++; char = 0; phase = 'primary'; lineObj = null;

                        if (idx < pairs.length) { setTimeout(tick, pause); }

                        else { setTimeout(function () { aftermath.classList.add('tw-show'); }, 700); }

                    }

                }

            }

            // Start after hero fade-in settles

            setTimeout(tick, 1200);

        })();

        // ── End Typewriter ────────────────────────────────────────────────────────────



        // ── Hero Grid Rotation removed (grid no longer in DOM) ───────────────────────

    </script>

</body>



