<!DOCTYPE html>

<html lang="en">



<head>

    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sowaka — Employee Engagement & Wellness</title>

    <link

        href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,700;0,800;1,700&display=swap"

        rel="stylesheet" />

    <style>

        *,

        *::before,

        *::after {

            margin: 0;

            padding: 0;

            box-sizing: border-box

        }



        html {

            scroll-behavior: smooth;

            font-size: 16px

        }



        body {

            font-family: 'Sora', sans-serif;

            background: #fff;

            color: #1a1208;

            overflow-x: hidden;

            -webkit-font-smoothing: antialiased

        }



        :root {

            --rust: #8B2800;

            --rust2: #B83A10;

            --peach: #E8C5B0;

            --cream: #FDF6F0;

            --dark: #1A1208;

            --mid: #5C4033;

            --light: #F5EBE4;

            --border: #E8D5C5;

            --white: #fff;

        }



        /* --- UPDATED NAV SECTION --- */

        .nav {

            position: fixed;

            top: 0;

            left: 0;

            right: 0;

            z-index: 999;

            display: flex;

            align-items: center;

            justify-content: space-between;

            padding: 0 64px;

            height: 72px;

            background: rgba(255, 255, 255, 0.96);

            backdrop-filter: blur(16px);

            border-bottom: 1px solid var(--border);

        }



        .nav-logo {

            display: flex;

            align-items: center;

            gap: 8px;

            text-decoration: none

        }



        .nav-logo-text {

            font-family: 'Fraunces', serif;

            font-size: 1.5rem;

            font-weight: 800;

            color: var(--rust);

            letter-spacing: -0.5px

        }



        .nav-right {

            display: flex;

            align-items: center;

            gap: 32px;

            /* Space between links and buttons */

        }



        .nav-links {

            display: flex;

            align-items: center;

            gap: 28px;

            list-style: none;

            border-right: 1px solid var(--border);

            /* Visual Divider */

            padding-right: 32px;

            margin: 0;

        }



        .nav-links a {

            text-decoration: none;

            font-size: 0.875rem;

            font-weight: 500;

            color: var(--mid);

            transition: color .2s

        }



        .nav-links a:hover {

            color: var(--rust)

        }



        .nav-actions {

            display: flex;

            align-items: center;

            gap: 12px;

        }



        /* --- END UPDATED NAV SECTION --- */



        .btn-ghost {

            font-size: 0.875rem;

            font-weight: 500;

            color: var(--dark);

            text-decoration: none;

            padding: 10px 20px;

            border-radius: 100px;

            border: 1.5px solid var(--border);

            transition: all .2s;

            cursor: pointer;

            background: transparent

        }



        .btn-ghost:hover {

            border-color: var(--rust);

            color: var(--rust)

        }



        .btn-fill {

            font-size: 0.875rem;

            font-weight: 600;

            color: #fff;

            text-decoration: none;

            padding: 10px 22px;

            border-radius: 100px;

            background: var(--rust);

            transition: background .2s;

            border: none;

            cursor: pointer

        }



        .btn-fill:hover {

            background: var(--rust2)

        }



        /* HERO */

        .hero {

            padding: 60px 64px 80px;

            display: grid;

            grid-template-columns: 1fr 1fr;

            align-items: center;

            gap: 80px;

            min-height: calc(100vh - 72px - 90px);

            background: var(--cream);

        }



        .hero-eyebrow {

            display: inline-flex;

            align-items: center;

            gap: 8px;

            background: #fff;

            border: 1.5px solid var(--border);

            border-radius: 100px;

            padding: 6px 16px;

            margin-bottom: 28px;

            font-size: 0.78rem;

            font-weight: 600;

            color: var(--rust);

            letter-spacing: .5px;

            text-transform: uppercase

        }



        .hero-eyebrow-dot {

            width: 8px;

            height: 8px;

            border-radius: 50%;

            background: var(--rust);

            animation: pulse 2s infinite

        }



        @keyframes pulse {



            0%,

            100% {

                opacity: 1;

                transform: scale(1)

            }



            50% {

                opacity: .5;

                transform: scale(.8)

            }

        }



        .hero h1 {

            font-family: 'Fraunces', serif;

            font-size: clamp(2.4rem, 4.2vw, 3.6rem);

            font-weight: 800;

            line-height: 1.08;

            color: var(--dark);

            margin-bottom: 36px

        }



        .hero h1 em {

            font-style: italic;

            color: var(--rust)

        }



        .hero-actions {

            display: flex;

            gap: 12px;

            align-items: center;

            margin-bottom: 32px;

            flex-wrap: wrap

        }



        .hero-trust {

            display: flex;

            align-items: center;

            gap: 14px

        }



        .hero-avatars {

            display: flex

        }



        .hero-av {

            width: 36px;

            height: 36px;

            border-radius: 50%;

            border: 2.5px solid #fff;

            background: linear-gradient(135deg, var(--rust), var(--rust2));

            margin-left: -10px;

            display: flex;

            align-items: center;

            justify-content: center;

            font-size: 0.65rem;

            font-weight: 700;

            color: #fff

        }



        .hero-av:first-child {

            margin-left: 0

        }



        .hero-trust-text {

            font-size: 0.82rem;

            color: var(--mid);

            line-height: 1.5

        }



        .hero-trust-text strong {

            display: block;

            color: var(--dark);

            font-weight: 600;

            font-size: 0.85rem

        }



        .hero-tw-col {

            display: flex;

            flex-direction: column;

            justify-content: center

        }



        /* HERO QUOTE */

        .hero-quote-wrap {

            grid-column: 1 / -1;

            text-align: center;

            border-top: 1px solid var(--border);

            padding-top: 28px;

            margin-top: 4px

        }



        .hero-quote {

            font-family: 'Fraunces', serif;

            font-style: italic;

            font-size: clamp(1rem, 1.6vw, 1.25rem);

            color: var(--mid);

            letter-spacing: 0.01em;

            display: block

        }



        .hero-quote-sub {

            font-size: 0.85rem;

            color: var(--mid);

            opacity: 0.65;

            margin-top: 8px;

            font-weight: 300;

            letter-spacing: 0.01em;

            display: block

        }



        /* TYPEWRITER */

        .hero-tw-block {

            margin-bottom: 24px;

            min-height: 360px;

            display: flex;

            flex-direction: column;

            gap: 0

        }



        .tw-line {

            opacity: 0;

            margin-bottom: 22px;

            transition: opacity .4s ease

        }



        .tw-line.tw-visible {

            opacity: 1

        }



        .tw-primary {

            font-size: 1.08rem;

            font-weight: 700;

            color: var(--dark);

            line-height: 1.45;

            display: block

        }



        .tw-secondary {

            font-size: 0.95rem;

            font-weight: 300;

            color: var(--mid);

            line-height: 1.5;

            display: block;

            margin-top: 5px

        }



        .tw-cursor {

            display: inline-block;

            color: var(--rust);

            font-weight: 400;

            animation: tw-blink .65s step-end infinite

        }



        @keyframes tw-blink {



            0%,

            100% {

                opacity: 1

            }



            50% {

                opacity: 0

            }

        }



        .hero-aftermath {

            font-size: 1rem;

            line-height: 1.68;

            color: var(--mid);

            opacity: 0;

            transition: opacity 1.1s ease

        }



        .hero-aftermath em {

            color: var(--rust);

            font-style: italic;

            font-weight: 600

        }



        .hero-aftermath.tw-show {

            opacity: 1

        }



        /* HERO VISUAL */

        .hero-visual {

            display: grid;

            grid-template-columns: 1fr 1fr;

            grid-template-rows: auto auto;

            gap: 14px

        }



        .hv {

            border-radius: 22px;

            overflow: hidden;

            position: relative;

            min-height: 185px;

            transition: opacity 1.2s ease;

            background-size: cover;

            background-position: center

        }



        .hv.tall {

            grid-row: span 2;

            min-height: 390px

        }



        .hv-bg {

            position: absolute;

            inset: 0;

            display: flex;

            align-items: flex-end;

            padding: 20px

        }



        .hv-emoji {

            display: none

        }



        .hv-tag {

            display: none !important

        }



        .hv h4 {

            font-size: 0.95rem;

            font-weight: 700;

            color: #fff;

            text-shadow: 0 1px 4px rgba(0, 0, 0, .35)

        }



        .hv-1 {

            background: linear-gradient(160deg, #8B2800, #C04A1A)

        }



        .hv-2 {

            background: linear-gradient(160deg, #C8765A, #E8A080)

        }



        .hv-3 {

            background: linear-gradient(160deg, #5C4033, #8B6355)

        }



        .hv-4 {

            background: linear-gradient(160deg, #D4956A, #E8C5B0)

        }



        /* MARQUEE */

        .marquee-section {

            overflow: hidden;

            padding-top: 72px;

            border-top: 1px solid var(--border);

            border-bottom: 1px solid var(--border);

            background: #fff

        }



        .marquee-label {

            text-align: center;

            padding: 20px 0 6px;

            font-size: 0.73rem;

            letter-spacing: 2px;

            text-transform: uppercase;

            color: var(--mid);

            font-weight: 500

        }



        .marquee-wrap {

            overflow: hidden;

            padding: 14px 0 22px

        }



        .marquee-track {

            display: flex;

            width: max-content;

            animation: marquee 40s linear infinite

        }



        .marquee-track:hover {

            animation-play-state: paused

        }



        @keyframes marquee {

            from {

                transform: translateX(0)

            }



            to {

                transform: translateX(-50%)

            }

        }



        .marquee-item {

            display: flex;

            align-items: center;

            gap: 8px;

            padding: 0 28px;

            white-space: nowrap;

            font-size: 0.9rem;

            font-weight: 600;

            color: var(--mid);

            border-right: 1px solid var(--border)

        }



        .marquee-item:last-child {

            border-right: none

        }



        .marquee-item-icon {

            display: none

        }



        /* STATS */

        .stats-bar {

            display: grid;

            grid-template-columns: repeat(3, 1fr);

            gap: 1px;

            background: var(--border)

        }



        .stat {

            background: #fff;

            padding: 40px 32px;

            text-align: center

        }



        .stat-n {

            font-family: 'Fraunces', serif;

            font-size: 3rem;

            font-weight: 800;

            color: var(--rust);

            line-height: 1;

            margin-bottom: 8px

        }



        .stat-l {

            font-size: 0.83rem;

            color: var(--mid);

            line-height: 1.5

        }



        /* SHARED SECTION */

        .section {

            padding: 96px 64px

        }



        .section.bg-cream {

            background: var(--cream)

        }



        .section.bg-dark {

            background: var(--dark)

        }



        .eyebrow {

            font-size: 0.73rem;

            letter-spacing: 2.5px;

            text-transform: uppercase;

            font-weight: 600;

            color: var(--rust);

            margin-bottom: 14px;

            display: block

        }



        .section.bg-dark .eyebrow {

            color: var(--peach)

        }



        .section-title {

            font-family: 'Fraunces', serif;

            font-size: clamp(2rem, 3.5vw, 2.8rem);

            font-weight: 800;

            color: var(--dark);

            line-height: 1.12;

            margin-bottom: 16px

        }



        .section.bg-dark .section-title {

            color: #fff

        }



        .section-sub {

            font-size: 1rem;

            color: var(--mid);

            max-width: 560px;

            line-height: 1.72;

            font-weight: 300

        }



        .section.bg-dark .section-sub {

            color: rgba(255, 255, 255, .55)

        }



        .section-head {

            margin-bottom: 52px

        }



        /* COMPARISON */

        .cmp-table {

            display: grid;

            grid-template-columns: 1fr 1fr;

            gap: 0;

            border: 1.5px solid rgba(255, 255, 255, .1);

            border-radius: 20px;

            overflow: hidden;

            margin-top: 48px

        }



        .cmp-col-head {

            display: flex;

            align-items: center;

            gap: 10px;

            padding: 20px 28px;

            font-size: 0.95rem;

            font-weight: 700;

            letter-spacing: .2px

        }



        .cmp-col-head-sowaka {

            background: rgba(255, 255, 255, .06);

            color: #fff;

            border-bottom: 1px solid rgba(255, 255, 255, .1)

        }



        .cmp-col-head-others {

            background: rgba(255, 255, 255, .03);

            color: rgba(255, 255, 255, .5);

            border-left: 1px solid rgba(255, 255, 255, .1);

            border-bottom: 1px solid rgba(255, 255, 255, .1)

        }



        .cmp-dot {

            width: 12px;

            height: 12px;

            border-radius: 50%;

            flex-shrink: 0

        }



        .cmp-dot-green {

            background: #4ADE80

        }



        .cmp-dot-red {

            background: #F87171

        }



        .cmp-row-sowaka {

            padding: 18px 28px;

            display: flex;

            align-items: center;

            gap: 12px;

            font-size: 0.88rem;

            color: #fff;

            border-bottom: 1px solid rgba(255, 255, 255, .07);

            background: rgba(255, 255, 255, .04)

        }



        .cmp-row-others {

            padding: 18px 28px;

            display: flex;

            align-items: center;

            gap: 12px;

            font-size: 0.88rem;

            color: rgba(255, 255, 255, .45);

            border-bottom: 1px solid rgba(255, 255, 255, .07);

            border-left: 1px solid rgba(255, 255, 255, .1)

        }



        .cmp-row-sowaka:last-child,

        .cmp-row-others:last-child {

            border-bottom: none

        }



        .cmp-check {

            font-size: 1rem;

            flex-shrink: 0;

            color: #4ADE80

        }



        .cmp-cross {

            font-size: 1rem;

            flex-shrink: 0;

            color: #F87171

        }



        /* Tablet: keep 2 columns, tighten spacing */

        @media(max-width:960px) {

            .cmp-col-head {

                padding: 16px 20px

            }



            .cmp-row-sowaka,

            .cmp-row-others {

                padding: 14px 20px;

                font-size: 0.84rem

            }

        }



        /* Mobile: keep 2 columns, compress further */

        @media(max-width:640px) {

            #why-sowaka {

                padding: 60px 16px

            }



            .cmp-table {

                margin-top: 32px;

                border-radius: 14px

            }



            .cmp-col-head {

                padding: 12px 14px;

                font-size: 0.8rem;

                gap: 7px

            }



            .cmp-dot {

                width: 9px;

                height: 9px

            }



            .cmp-row-sowaka,

            .cmp-row-others {

                padding: 12px 14px;

                font-size: 0.78rem;

                gap: 8px;

                line-height: 1.5

            }



            .cmp-check,

            .cmp-cross {

                font-size: 0.85rem;

                flex-shrink: 0

            }

        }



        /* TABS + ACTIVITIES */

        .act-tabs {

            display: flex;

            gap: 0;

            margin-bottom: 0;

            overflow-x: auto;

            border-bottom: 2px solid var(--border)

        }



        .act-tab {

            padding: 13px 24px;

            font-size: 0.85rem;

            font-weight: 600;

            cursor: pointer;

            border: none;

            background: transparent;

            color: var(--mid);

            border-bottom: 3px solid transparent;

            margin-bottom: -2px;

            transition: all .2s;

            white-space: nowrap

        }



        .act-tab.active {

            color: var(--rust);

            border-bottom-color: var(--rust)

        }



        .act-tab:hover:not(.active) {

            color: var(--dark)

        }



        .act-panels {

            margin-top: 32px

        }



        .act-panel {

            display: none

        }



        .act-panel.active {

            display: grid;

            grid-template-columns: 1fr 1fr;

            gap: 18px

        }



        .act-card {

            background: #fff;

            border-radius: 20px;

            padding: 28px;

            border: 1.5px solid var(--border);

            display: flex;

            gap: 18px;

            align-items: flex-start;

            transition: all .25s;

            cursor: default

        }



        .act-card:hover {

            border-color: var(--rust);

            box-shadow: 0 6px 36px rgba(139, 40, 0, .09);

            transform: translateY(-3px)

        }



        .act-card.act-hero {

            grid-column: span 2;

            background: linear-gradient(135deg, var(--rust) 0%, var(--rust2) 100%);

            border: none;

            flex-wrap: wrap;

            gap: 18px

        }



        .act-icon-wrap {

            display: none

        }



        .act-card.act-hero .act-icon-wrap {

            background: rgba(255, 255, 255, .15)

        }



        .act-card.act-hero .act-body h3 {

            color: #fff

        }



        .act-card.act-hero .act-body p {

            color: rgba(255, 255, 255, .75)

        }



        .act-body h3 {

            font-size: 1.05rem;

            font-weight: 700;

            color: var(--dark);

            margin-bottom: 7px

        }



        .act-body p {

            font-size: 0.875rem;

            color: var(--mid);

            line-height: 1.65

        }



        .act-pill {

            background: rgba(255, 255, 255, .22);

            color: #fff;

            font-size: 0.72rem;

            font-weight: 700;

            letter-spacing: .5px;

            padding: 5px 14px;

            border-radius: 100px;

            white-space: nowrap;

            align-self: flex-start;

            margin-left: auto

        }



        /* PILLARS */

        .pillars-grid {

            display: grid;

            grid-template-columns: repeat(3, 1fr);

            gap: 16px

        }



        .pillar-card {

            background: var(--cream);

            border: 1.5px solid var(--border);

            border-radius: 16px;

            overflow: hidden;

            transition: all .25s;

            display: flex;

            flex-direction: row;

            height: 130px

        }



        .pillar-card:hover {

            border-color: var(--rust);

            background: #fff

        }



        .pillar-img {

            width: 130px;

            min-width: 130px;

            object-fit: cover;

            display: block;

            flex-shrink: 0

        }



        .pillar-icon {

            display: none

        }



        .pillar-body {

            padding: 20px 18px;

            display: flex;

            flex-direction: column;

            justify-content: center

        }



        .pillar-card h3 {

            font-size: 0.92rem;

            font-weight: 700;

            color: var(--dark);

            margin-bottom: 7px

        }



        .pillar-card p {

            font-size: 0.8rem;

            color: var(--mid);

            line-height: 1.6

        }



        /* TESTIMONIALS */

        .test-head {

            display: flex;

            align-items: flex-end;

            justify-content: space-between;

            flex-wrap: wrap;

            gap: 16px;

            margin-bottom: 36px

        }



        .test-nav {

            display: flex;

            gap: 10px

        }



        .test-btn {

            width: 42px;

            height: 42px;

            border-radius: 50%;

            border: 1.5px solid var(--border);

            background: #fff;

            cursor: pointer;

            font-size: 1rem;

            color: var(--dark);

            display: flex;

            align-items: center;

            justify-content: center;

            transition: all .2s

        }



        .test-btn:hover {

            border-color: var(--rust);

            color: var(--rust)

        }



        .test-scroll {

            display: flex;

            gap: 18px;

            overflow-x: auto;

            scroll-snap-type: x mandatory;

            -ms-overflow-style: none;

            scrollbar-width: none;

            padding-bottom: 4px

        }



        .test-scroll::-webkit-scrollbar {

            display: none

        }



        .test-card {

            background: var(--cream);

            border: 1.5px solid var(--border);

            border-radius: 20px;

            overflow: hidden;

            min-width: 300px;

            max-width: 340px;

            scroll-snap-align: start;

            flex-shrink: 0

        }



        .test-event-img {

            width: 100%;

            height: 160px;

            object-fit: cover;

            display: block

        }



        .test-body {

            padding: 22px 24px 24px

        }



        .test-quote-mark {

            font-size: 1.5rem;

            color: var(--rust);

            line-height: 1;

            margin-bottom: 14px

        }



        .test-text {

            font-size: 0.875rem;

            color: var(--dark);

            line-height: 1.72;

            margin-bottom: 22px;

            font-style: italic

        }



        .test-author {

            display: flex;

            align-items: center;

            gap: 12px

        }



        .test-avatar {

            width: 44px;

            height: 44px;

            border-radius: 50%;

            border: 2.5px solid var(--border);

            object-fit: cover;

            flex-shrink: 0;

            display: block

        }



        .test-name {

            font-size: 0.83rem;

            font-weight: 700;

            color: var(--dark)

        }



        .test-role {

            font-size: 0.75rem;

            color: var(--mid)

        }



        /* OCCASIONS */

        .occ-grid {

            display: grid;

            grid-template-columns: repeat(4, 1fr);

            gap: 16px;

            margin-top: 48px

        }



        .occ-card {

            position: relative;

            overflow: hidden;

            border-radius: 20px;

            min-height: 240px;

            display: flex;

            align-items: flex-end;

            padding: 22px;

            transition: all .3s;

            background-size: cover;

            background-position: center;

            border: 1px solid rgba(255, 255, 255, .08)

        }



        .occ-card::after {

            content: '';

            position: absolute;

            inset: 0;

            background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.2) 55%, transparent 100%);

            border-radius: 20px;

            transition: opacity .3s

        }



        .occ-card:hover {

            transform: translateY(-5px);

            border-color: var(--peach)

        }



        .occ-card:hover::after {

            opacity: .85

        }



        .occ-card-text {

            position: relative;

            z-index: 1;

            text-align: left

        }



        .occ-icon {

            display: none

        }



        .occ-card h3 {

            font-size: 0.95rem;

            font-weight: 700;

            color: #fff;

            margin-bottom: 4px

        }



        .occ-card p {

            font-size: 0.8rem;

            color: rgba(255, 255, 255, .65)

        }



        /* CTA */

        .cta-wrap {

            text-align: center

        }



        .cta-wrap h2 {

            font-family: 'Fraunces', serif;

            font-size: clamp(2rem, 4vw, 3.2rem);

            font-weight: 800;

            color: var(--dark);

            line-height: 1.1;

            margin-bottom: 16px

        }



        .cta-wrap h2 em {

            font-style: italic;

            color: var(--rust)

        }



        .cta-wrap p {

            font-size: 1rem;

            color: var(--mid);

            margin-bottom: 36px;

            line-height: 1.72;

            max-width: 500px;

            margin-left: auto;

            margin-right: auto

        }



        .cta-btns {

            display: flex;

            gap: 12px;

            justify-content: center;

            flex-wrap: wrap

        }



        .cta-sub {

            margin-top: 18px;

            font-size: 0.82rem;

            color: var(--mid)

        }



        .cta-sub a {

            color: var(--rust);

            text-decoration: none;

            font-weight: 600

        }



        /* FOOTER */

        footer {

            padding: 30px 64px;

            display: flex;

            align-items: center;

            justify-content: space-between;

            border-top: 1px solid var(--border);

            background: #fff;

            flex-wrap: wrap;

            gap: 16px

        }



        .footer-logo {

            font-family: 'Fraunces', serif;

            font-size: 1.3rem;

            font-weight: 800;

            color: var(--rust)

        }



        footer p {

            font-size: 0.8rem;

            color: var(--mid)

        }



        .footer-links {

            display: flex;

            gap: 22px

        }



        .footer-links a {

            font-size: 0.8rem;

            color: var(--mid);

            text-decoration: none;

            transition: color .2s

        }



        .footer-links a:hover {

            color: var(--rust)

        }



        /* FADE */

        .fade {

            opacity: 0;

            transform: translateY(22px);

            transition: opacity .65s ease, transform .65s ease

        }



        .fade.in {

            opacity: 1;

            transform: translateY(0)

        }



        /* RESPONSIVE */

        @media(max-width:960px) {

            .nav {

                padding: 0 24px

            }



            .nav-links,

            .nav-actions .btn-ghost {

                display: none

            }



            .hero {

                grid-template-columns: 1fr;

                padding: 100px 24px 56px

            }



            .hero-tw-col {

                margin-top: 8px

            }



            .stats-bar {

                grid-template-columns: repeat(3, 1fr)

            }



            .section {

                padding: 64px 24px

            }



            .act-panel.active {

                grid-template-columns: 1fr

            }



            .act-card.act-hero {

                grid-column: span 1

            }



            .act-pill {

                margin-left: 0;

                margin-top: 10px

            }



            .pillars-grid {

                grid-template-columns: 1fr 1fr

            }



            .occ-grid {

                grid-template-columns: 1fr 1fr

            }



            footer {

                padding: 24px;

                flex-direction: column;

                text-align: center

            }



            .footer-links {

                justify-content: center

            }

        }

    </style>

</head>



